@import './custom-block'
@import './animation'

$navbar-main-height = $navbarHeight - $navbar-sub-navbar-height
// 三列宽度统一使用 px，避免 Stylus 混合计算 px/rem 时生成错误的媒体查询。
$page-column-width = $contentWidth + 80px
$page-layout-without-toc-width = $sidebarWidth + $page-column-width
$page-layout-without-sidebar-width = $page-column-width + $vuepress-toc-width
$page-layout-width = $sidebarWidth + $page-layout-without-sidebar-width

.custom-page-class
	word-break break-word
	position relative

	/* 首页几个logo的排版 */
	.flex-img-group-view
		display flex
		flex-direction row
		margin 10px 0

		.barcode-view
			display flex
			align-items center
			flex-direction column
			margin 0 5px
			margin-bottom 20px

			b
				text-align center

	.uniapp-home-content
		display flex
		flex-wrap wrap
		width 100%
		justify-content center

		.uniapp-home-content-item
			margin-bottom 20px

			.uniapp-home-content-item-image
				width 55px
				height 55px
				flex-shrink 0

				img
					height 100%

			p.uniapp-home-content-item-text
				margin-bottom 0px
				letter-spacing 0px
				color #333

			.uniapp-home-content-item-title
				font-size 16px

	@media screen and (min-width 768px)
		.flex-img-group-view
			justify-content space-around

		.uniapp-home-content-item
			width 32%

	@media screen and (max-width 600px)
		.uniapp-home-content-item
			width 100%
			display flex
			flex-direction row

		.uniapp-home-content-item-header
			display flex
			flex-direction column
			padding-left 15px

		.uniapp-home-content-item-title
			line-height 10px

body.forbid_scroll
	height 100%
	overflow hidden

.content-container
	width 100%
	min-width 0
	max-width $page-layout-without-toc-width
	margin 0 auto
	padding-top $navbarHeight
	box-sizing border-box

.navbar:not(.navbar-with-subnav) ~ .content-container
	padding-top $navbar-main-height

.theme-container.no-navbar .content-container
	padding-top 0

main.page
	padding-bottom 0px
	padding-right 0px

.table-of-contents
	@media (min-width $vuepress-display-min-width)
		&
			display none !important

	@media (max-width: ($vuepress-display-min-width - 1px))
		&
			display block !important

@media (min-width: ($MQMobile + 1px))
	.content-container
		display flex
		align-items flex-start

	.content-container > .sidebar-column
		flex 0 0 $sidebarWidth
		width $sidebarWidth
		height s('calc(100vh - %s)', $navbarHeight)

	.content-container > .sidebar-column > .sidebar
		position relative
		width $sidebarWidth
		height 100%
		top auto
		left auto
		bottom auto

	.content-container > .page
		flex 1 1 $page-column-width
		min-width 0
		max-width $page-column-width
		padding-left 0

	.theme-container.no-sidebar .content-container
		max-width $page-column-width

	.theme-container.no-sidebar .content-container > .sidebar-column
		display none

	.navbar:not(.navbar-with-subnav) ~ .content-container > .sidebar-column
		height s('calc(100vh - %s)', $navbar-main-height)

	.theme-container.no-navbar .content-container > .sidebar-column
		height 100vh

	// 有二级导航时先随内容滚动，一级导航收起后再固定侧栏。
	.navbar-collapsed ~ .content-container > .sidebar-column > .sidebar,
	.navbar:not(.navbar-with-subnav) ~ .content-container > .sidebar-column > .sidebar,
	.theme-container.no-navbar .content-container > .sidebar-column > .sidebar
		position fixed
		// 使用占位列提供的静态横向位置，fixed 前后不会发生水平跳动。
		left auto
		bottom 0
		height auto

	.navbar-collapsed ~ .content-container > .sidebar-column > .sidebar
		top $navbar-sub-navbar-height

	.navbar:not(.navbar-with-subnav) ~ .content-container > .sidebar-column > .sidebar
		top $navbar-main-height

	.theme-container.no-navbar .content-container > .sidebar-column > .sidebar
		top 0

@media (min-width: $vuepress-display-min-width)
	.content-container
		max-width $page-layout-width

	.content-container > .toc-column
		display block
		flex 0 0 $vuepress-toc-width
		width $vuepress-toc-width
		height s('calc(100vh - %s)', $navbarHeight)

	.content-container > .toc-column > .vuepress-toc:not(.table-of-contents-sticker)
		display block !important

	.content-container > .toc-column > .vuepress-toc
		position relative
		width 100%
		max-height s('calc(100vh - %s)', $navbarHeight)
		top auto
		right auto

	.navbar:not(.navbar-with-subnav) ~ .content-container > .toc-column
		height s('calc(100vh - %s)', $navbar-main-height)

	.theme-container.no-navbar .content-container > .toc-column
		height 100vh

	.theme-container.no-sidebar .content-container
		max-width $page-layout-without-sidebar-width

	.theme-container.no-toc .content-container
		max-width $page-layout-without-toc-width

	.theme-container.no-toc .content-container > .toc-column
		display none

	.theme-container.no-sidebar.no-toc .content-container
		max-width $page-column-width

	// Toc 与 Sidebar 使用同一个折叠状态切换 fixed，不再由滚动事件逐帧修改 top。
	.navbar-collapsed ~ .content-container > .toc-column > .vuepress-toc,
	.navbar:not(.navbar-with-subnav) ~ .content-container > .toc-column > .vuepress-toc,
	.theme-container.no-navbar .content-container > .toc-column > .vuepress-toc
		position fixed
		left auto
		right auto
		width $vuepress-toc-width

	.navbar-collapsed ~ .content-container > .toc-column > .vuepress-toc
		top $navbar-sub-navbar-height
		max-height s('calc(100vh - %s)', $navbar-sub-navbar-height)

	.navbar:not(.navbar-with-subnav) ~ .content-container > .toc-column > .vuepress-toc
		top $navbar-main-height
		max-height s('calc(100vh - %s)', $navbar-main-height)

	.theme-container.no-navbar .content-container > .toc-column > .vuepress-toc
		top 0
		max-height 100vh

@media (max-width $MQMobile)
	.content-container
		max-width none
		padding-top $navbar-main-height

	.table-of-contents
		margin-top: $navbarHeight - 6rem !important

@media (min-width $MQMobile)
	.nav-dropdown
		z-index 1

{$contentClass}:not(.custom)
	> *:first-child
		margin-top 0

img
	max-width 100% !important

table
	position relative

table.uni-platform-table
	tbody > tr:first-child > td
		font-weight 600

ul > li, p > a
	word-break break-all

h1, h2, h3, h4, h5, h6
	{$contentClass}:not(.custom) > &
		$pd = 5.5rem
		$mt = $pd - 1 - $navbarHeight
		margin-top $mt
		padding-top $pd

		&:first-child
			margin-top 3rem - $navbarHeight
			padding-top: ($navbarHeight - 3rem)

.sidebar
	.sidebar-group.is-sub-group>.sidebar-heading
		word-break break-word

		&:not(.clickable)
			opacity 1

	.sidebar-link
		word-break break-word

.uni-loading
	width 20px
	height 20px
	display inline-block
	vertical-align middle
	animation uni-loading 1s steps(12, end) infinite
	background-size 100%
	background-color transparent
	background-image url('data:image/svg+xml;base64, ')
	background-repeat no-repeat

@keyframes uni-loading
	0%
		transform rotate3d(0, 0, 1, 0deg)

	100%
		transform rotate3d(0, 0, 1, 360deg)

.theme-default-content code
	color #e96900

div[class][class*='language-']::before
	right 80px

div[class~=language-uts]:before
	content: "uts";

h4
	font-size: 1.15em

h5
	font-size: 1em

h6
	font-size: 0.83em

th, td
	padding 0.4rem 0.6rem
